
{
  "entities": {
    "ParentProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ParentProfile",
      "type": "object",
      "description": "Represents a parent user profile within the Chore Champion application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ParentProfile entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the parent.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "First name of the parent."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the parent."
        }
      },
      "required": [
        "id",
        "email",
        "firstName",
        "lastName"
      ]
    },
    "ChampionProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChampionProfile",
      "type": "object",
      "description": "Represents a child (champion) profile within the Chore Champion application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ChampionProfile entity."
        },
        "parentId": {
          "type": "string",
          "description": "Reference to ParentProfile. (Relationship: ParentProfile 1:N ChampionProfile)"
        },
        "name": {
          "type": "string",
          "description": "First name of the champion."
        },
        "username": {
          "type": "string",
          "description": "The champion's username."
        },
        "email": {
          "type": "string",
          "description": "The champion's email address.",
          "format": "email"
        },
        "points": {
          "type": "number",
          "description": "Total reward points earned by the champion."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL for the champion's avatar image.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "parentId",
        "name",
        "username",
        "email",
        "points"
      ]
    },
    "Chore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Chore",
      "type": "object",
      "description": "Represents a chore that can be assigned to a champion.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Chore entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the chore."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the chore."
        },
        "pointsValue": {
          "type": "number",
          "description": "Number of reward points awarded for completing the chore."
        },
        "preset": {
          "type": "boolean",
          "description": "Indicates whether the chore is a preset or custom chore."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "pointsValue",
        "preset"
      ]
    },
    "AssignedChore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AssignedChore",
      "type": "object",
      "description": "Represents a chore assigned to a specific champion on a specific date.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AssignedChore entity."
        },
        "championId": {
          "type": "string",
          "description": "Reference to ChampionProfile. (Relationship: ChampionProfile 1:N AssignedChore)"
        },
        "choreId": {
          "type": "string",
          "description": "Reference to Chore. (Relationship: Chore 1:N AssignedChore)"
        },
        "choreName": {
          "type": "string",
          "description": "Snapshot of the chore name at time of assignment."
        },
        "pointsValue": {
          "type": "number",
          "description": "Points value at time of assignment."
        },
        "dueDate": {
          "type": "string",
          "description": "The date the chore is due.",
          "format": "date-time"
        },
        "completed": {
          "type": "boolean",
          "description": "Indicates whether the chore has been completed."
        },
        "approved": {
          "type": "boolean",
          "description": "Indicates whether the completion was approved by a parent."
        }
      },
      "required": [
        "id",
        "championId",
        "choreId",
        "dueDate",
        "completed"
      ]
    },
    "Reward": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reward",
      "type": "object",
      "description": "Represents a reward that can be redeemed by a champion.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Reward entity."
        },
        "parentId": {
          "type": "string",
          "description": "Reference to ParentProfile. (Relationship: ParentProfile 1:N Reward)"
        },
        "name": {
          "type": "string",
          "description": "Name of the reward."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the reward."
        },
        "points": {
          "type": "number",
          "description": "Number of points required to redeem the reward."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "parentId",
        "name",
        "points"
      ]
    },
    "RedeemedReward": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RedeemedReward",
      "type": "object",
      "description": "Represents a reward that has been redeemed by a champion.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the RedeemedReward entity."
        },
        "championId": {
          "type": "string",
          "description": "Reference to ChampionProfile. (Relationship: ChampionProfile 1:N RedeemedReward)"
        },
        "rewardId": {
          "type": "string",
          "description": "Reference to Reward. (Relationship: Reward 1:N RedeemedReward)"
        },
        "rewardName": {
          "type": "string",
          "description": "Snapshot of the reward name."
        },
        "pointsCost": {
          "type": "number",
          "description": "Points spent."
        },
        "redemptionDate": {
          "type": "string",
          "description": "The date the reward was redeemed.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "fulfilled"],
          "description": "Status of the redemption."
        }
      },
      "required": [
        "id",
        "championId",
        "rewardId",
        "redemptionDate",
        "status"
      ]
    },
    "FamilyMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FamilyMessage",
      "type": "object",
      "description": "Represents a message sent within the family chat.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatarUrl": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["parent", "champion"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "senderName", "senderRole", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "ParentProfile",
          "schema": {
            "$ref": "#/backend/entities/ParentProfile"
          },
          "description": "Stores parent user profiles."
        }
      },
      {
        "path": "/users/{userId}/chores/{choreId}",
        "definition": {
          "entityName": "Chore",
          "schema": {
            "$ref": "#/backend/entities/Chore"
          },
          "description": "Parent-specific custom chore library."
        }
      },
      {
        "path": "/users/{userId}/rewards/{rewardId}",
        "definition": {
          "entityName": "Reward",
          "schema": {
            "$ref": "#/backend/entities/Reward"
          },
          "description": "Parent-specific custom reward library."
        }
      },
      {
        "path": "/users/{userId}/messages/{messageId}",
        "definition": {
          "entityName": "FamilyMessage",
          "schema": {
            "$ref": "#/backend/entities/FamilyMessage"
          },
          "description": "Shared family communication hub."
        }
      },
      {
        "path": "/champions/{championId}",
        "definition": {
          "entityName": "ChampionProfile",
          "schema": {
            "$ref": "#/backend/entities/ChampionProfile"
          },
          "description": "Champion profiles."
        }
      },
      {
        "path": "/champions/{championId}/assignedChores/{assignedChoreId}",
        "definition": {
          "entityName": "AssignedChore",
          "schema": {
            "$ref": "#/backend/entities/AssignedChore"
          },
          "description": "Chores assigned to a champion."
        }
      },
      {
        "path": "/champions/{championId}/redeemedRewards/{redeemedRewardId}",
        "definition": {
          "entityName": "RedeemedReward",
          "schema": {
            "$ref": "#/backend/entities/RedeemedReward"
          },
          "description": "Rewards redeemed by a champion."
        }
      },
      {
        "path": "/chores/{choreId}",
        "definition": {
          "entityName": "Chore",
          "schema": {
            "$ref": "#/backend/entities/Chore"
          },
          "description": "Global preset chores."
        }
      }
    ]
  }
}
