
{
  "entities": {
    "ParentProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ParentProfile",
      "type": "object",
      "description": "Represents a parent user profile within the QuestKind application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ParentProfile entity."
        },
        "familyId": {
          "type": "string",
          "description": "Shared identifier for grouping parents within the same family."
        },
        "email": {
          "type": "string",
          "description": "Email address of the parent.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "Phone number of the parent."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the parent."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the parent."
        },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "approvalAlerts": { "type": "boolean" },
            "rewardMilestones": { "type": "boolean" },
            "rewardClaimed": { "type": "boolean" },
            "chatAlerts": { "type": "boolean" }
          }
        }
      },
      "required": [
        "id",
        "familyId",
        "email",
        "firstName",
        "lastName"
      ]
    },
    "AdventurerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdventurerProfile",
      "type": "object",
      "description": "Represents a child (adventurer) profile within the QuestKind application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AdventurerProfile entity."
        },
        "parentId": {
          "type": "string",
          "description": "Reference to ParentProfile. (Relationship: ParentProfile 1:N AdventurerProfile)"
        },
        "name": {
          "type": "string",
          "description": "First name of the adventurer."
        },
        "username": {
          "type": "string",
          "description": "The adventurer's username (login code)."
        },
        "email": {
          "type": "string",
          "description": "The adventurer's internal email address.",
          "format": "email"
        },
        "points": {
          "type": "number",
          "description": "Total reward points earned by the adventurer."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL for the adventurer's avatar image.",
          "format": "uri"
        },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "newQuestAlerts": { "type": "boolean" },
            "questApprovedAlerts": { "type": "boolean" },
            "rewardMilestoneAlerts": { "type": "boolean" },
            "chatAlerts": { "type": "boolean" }
          }
        }
      },
      "required": [
        "id",
        "parentId",
        "name",
        "username",
        "email",
        "points"
      ]
    },
    "Chore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Chore",
      "type": "object",
      "description": "Represents a quest (chore) that can be assigned to an adventurer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Chore entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the quest."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the quest."
        },
        "pointsValue": {
          "type": "number",
          "description": "Number of reward points awarded for completing the quest."
        },
        "preset": {
          "type": "boolean",
          "description": "Indicates whether the quest is a preset or custom quest."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "pointsValue",
        "preset"
      ]
    },
    "AssignedChore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AssignedChore",
      "type": "object",
      "description": "Represents a quest assigned to a specific adventurer on a specific date.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AssignedChore entity."
        },
        "championId": {
          "type": "string",
          "description": "Reference to AdventurerProfile."
        },
        "choreId": {
          "type": "string",
          "description": "Reference to Chore."
        },
        "choreName": {
          "type": "string",
          "description": "Snapshot of the quest name at time of assignment."
        },
        "pointsValue": {
          "type": "number",
          "description": "Points value at time of assignment."
        },
        "dueDate": {
          "type": "string",
          "description": "The date the quest is due.",
          "format": "date-time"
        },
        "completed": {
          "type": "boolean",
          "description": "Indicates whether the quest has been completed."
        },
        "approved": {
          "type": "boolean",
          "description": "Indicates whether the completion was approved by a parent."
        }
      },
      "required": [
        "id",
        "championId",
        "choreId",
        "dueDate",
        "completed"
      ]
    },
    "Reward": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reward",
      "type": "object",
      "description": "Represents a reward that can be redeemed by an adventurer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Reward entity."
        },
        "parentId": {
          "type": "string",
          "description": "Reference to ParentProfile."
        },
        "name": {
          "type": "string",
          "description": "Name of the reward."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the reward."
        },
        "points": {
          "type": "number",
          "description": "Number of points required to redeem the reward."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "parentId",
        "name",
        "points"
      ]
    },
    "RedeemedReward": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RedeemedReward",
      "type": "object",
      "description": "Represents a reward that has been redeemed by an adventurer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the RedeemedReward entity."
        },
        "championId": {
          "type": "string",
          "description": "Reference to AdventurerProfile."
        },
        "rewardId": {
          "type": "string",
          "description": "Reference to Reward."
        },
        "rewardName": {
          "type": "string",
          "description": "Snapshot of the reward name."
        },
        "pointsCost": {
          "type": "number",
          "description": "Points spent."
        },
        "redemptionDate": {
          "type": "string",
          "description": "The date the reward was redeemed.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "fulfilled"],
          "description": "Status of the redemption."
        }
      },
      "required": [
        "id",
        "championId",
        "rewardId",
        "redemptionDate",
        "status"
      ]
    },
    "FamilyMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FamilyMessage",
      "type": "object",
      "description": "Represents a message sent within the family chat.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatarUrl": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["parent", "champion"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "senderName", "senderRole", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "ParentProfile",
          "schema": {
            "$ref": "#/backend/entities/ParentProfile"
          },
          "description": "Stores parent user profiles."
        }
      },
      {
        "path": "/users/{userId}/chores/{choreId}",
        "definition": {
          "entityName": "Chore",
          "schema": {
            "$ref": "#/backend/entities/Chore"
          },
          "description": "Parent-specific custom quest library."
        }
      },
      {
        "path": "/users/{userId}/rewards/{rewardId}",
        "definition": {
          "entityName": "Reward",
          "schema": {
            "$ref": "#/backend/entities/Reward"
          },
          "description": "Parent-specific custom reward library."
        }
      },
      {
        "path": "/users/{userId}/messages/{messageId}",
        "definition": {
          "entityName": "FamilyMessage",
          "schema": {
            "$ref": "#/backend/entities/FamilyMessage"
          },
          "description": "Shared family communication hub."
        }
      },
      {
        "path": "/champions/{championId}",
        "definition": {
          "entityName": "AdventurerProfile",
          "schema": {
            "$ref": "#/backend/entities/AdventurerProfile"
          },
          "description": "Adventurer profiles."
        }
      },
      {
        "path": "/champions/{championId}/assignedChores/{assignedChoreId}",
        "definition": {
          "entityName": "AssignedChore",
          "schema": {
            "$ref": "#/backend/entities/AssignedChore"
          },
          "description": "Quests assigned to an adventurer."
        }
      },
      {
        "path": "/champions/{championId}/redeemedRewards/{redeemedRewardId}",
        "definition": {
          "entityName": "RedeemedReward",
          "schema": {
            "$ref": "#/backend/entities/RedeemedReward"
          },
          "description": "Rewards redeemed by an adventurer."
        }
      },
      {
        "path": "/chores/{choreId}",
        "definition": {
          "entityName": "Chore",
          "schema": {
            "$ref": "#/backend/entities/Chore"
          },
          "description": "Global preset quests."
        }
      }
    ]
  }
}
