
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDocument() {
      return resource != null;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDocument();
    }

    // Check if parent profiles belong to the same family
    function isSameFamily(userId) {
      let currentUser = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let targetUser = get(/databases/$(database)/documents/users/$(userId)).data;
      return isSignedIn() && currentUser.familyId == targetUser.familyId;
    }

    // Check if the signed-in user is a champion belonging to the parent
    function isFamilyChampion(parentId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/champions/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/champions/$(request.auth.uid)).data.parentId == parentId;
    }

    // --- User (Parent) Profile Rules ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSameFamily(userId));
      allow list: if isSignedIn(); // Rely on 'familyId' where filter
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /rewards/{rewardId} {
        allow get, list: if isOwner(userId) || isFamilyChampion(userId);
        allow write: if isOwner(userId);
      }

      match /chores/{choreId} {
        allow get, list: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /messages/{messageId} {
        allow read, list: if isOwner(userId) || isFamilyChampion(userId);
        allow create: if isOwner(userId) || isFamilyChampion(userId);
        allow delete: if isOwner(userId);
      }
    }

    // --- Champion Profile Rules ---
    match /champions/{championId} {
      allow get: if isSignedIn() && (request.auth.uid == championId || (isExistingDocument() && request.auth.uid == resource.data.parentId));
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.parentId || request.auth.uid == championId);
      allow update: if isSignedIn() && (request.auth.uid == championId || (isExistingDocument() && request.auth.uid == resource.data.parentId));
      allow delete: if isSignedIn() && (isExistingDocument() && request.auth.uid == resource.data.parentId);

      match /assignedChores/{assignedChoreId} {
        allow get, list: if isSignedIn() && (request.auth.uid == championId || request.auth.uid == get(/databases/$(database)/documents/champions/$(championId)).data.parentId);
        allow create, delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/champions/$(championId)).data.parentId;
        allow update: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/champions/$(championId)).data.parentId ||
          (request.auth.uid == championId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completed']))
        );
      }

      match /redeemedRewards/{redeemedRewardId} {
        allow get, list: if isSignedIn() && (request.auth.uid == championId || request.auth.uid == get(/databases/$(database)/documents/champions/$(championId)).data.parentId);
        allow create: if isSignedIn() && request.auth.uid == championId;
        allow update, delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/champions/$(championId)).data.parentId;
      }
    }

    match /chores/{choreId} {
      allow get, list: if true;
      allow write: if false;
    }
  }
}
