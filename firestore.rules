/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model where all private user data is
 * nested within a `/users/{userId}` path. A user can only access documents within their own data tree.
 * This approach provides strong security guarantees by default.
 *
 * Data Structure: The data is organized hierarchically. A top-level `/users` collection holds individual
 * parent profiles. All data related to a parent—such as their children (`champions`), custom rewards (`rewards`),
 * and their children's activities (`assignedChores`, `redeemedRewards`)—are stored in subcollections under that
 * parent's specific document. A separate top-level `/chores` collection stores public, preset chore data.
 *
 * Key Security Decisions:
 * - Strict Ownership: All paths under `/users/{userId}` are accessible only to the authenticated user whose UID
 *   matches the `{userId}` wildcard.
 * - No User Listing: It is not possible for a client to list all documents in the `/users` collection,
 *   protecting user privacy.
 * - Public Read-Only Data: The `/chores` collection is publicly readable by anyone but is not writable
 *   by any client. This is ideal for app-wide configuration or preset data that should only be managed
 *   by developers or an admin console.
 * - Default Deny: Access is denied by default. Rules only explicitly grant permissions.
 *
 * Denormalization for Authorization: The data structure inherently supports efficient rules by using the document
 * path for authorization. For example, a rule for `/users/{userId}/champions/{championId}` can check ownership
 * simply by looking at the `userId` in the path, avoiding slow and costly `get()` calls to parent documents.
 * Additionally, documents contain foreign key fields (e.g., `parentId` on a ChampionProfile) that are validated
 * against the path on creation to ensure relational integrity.
 *
 * Structural Segregation: Private user data (`/users/{userId}/...`) is structurally separate from public data
 * (`/chores`). This segregation is critical for security and performance, as it allows for simple, safe list
 * operations on the public collection without any risk of exposing private data from another collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDocument() {
      return resource != null;
    }

    // Combines ownership and existence checks for secure updates and deletes.
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDocument();
    }

    // Validates that a user is creating their own profile document with a consistent ID.
    function isCreatingOwnProfile(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    // Validates that a user is creating a champion under their own profile.
    function isCreatingOwnedChampion(userId, championId) {
      return isOwner(userId) && request.resource.data.parentId == userId && request.resource.data.id == championId;
    }

    // Validates that a champion's parentId and id are not changed on update.
    function isUpdatingOwnedChampion(userId) {
      return isExistingOwner(userId) && request.resource.data.parentId == resource.data.parentId && request.resource.data.id == resource.data.id;
    }

    // Validates that a user is creating a reward under their own profile.
    function isCreatingOwnedReward(userId, rewardId) {
      return isOwner(userId) && request.resource.data.parentId == userId && request.resource.data.id == rewardId;
    }

    // Validates that a reward's parentId and id are not changed on update.
    function isUpdatingOwnedReward(userId) {
      return isExistingOwner(userId) && request.resource.data.parentId == resource.data.parentId && request.resource.data.id == resource.data.id;
    }

    // Validates creation of an assigned chore, linking it to the champion in the path.
    function isCreatingOwnedAssignedChore(userId, championId, assignedChoreId) {
      return isOwner(userId) && request.resource.data.championId == championId && request.resource.data.id == assignedChoreId;
    }

    // Validates immutability of an assigned chore's championId and id on update.
    function isUpdatingOwnedAssignedChore(userId) {
      return isExistingOwner(userId) && request.resource.data.championId == resource.data.championId && request.resource.data.id == resource.data.id;
    }

    // Validates creation of a redeemed reward, linking it to the champion in the path.
    function isCreatingOwnedRedeemedReward(userId, championId, redeemedRewardId) {
      return isOwner(userId) && request.resource.data.championId == championId && request.resource.data.id == redeemedRewardId;
    }

    // Validates immutability of a redeemed reward's championId and id on update.
    function isUpdatingOwnedRedeemedReward(userId) {
      return isExistingOwner(userId) && request.resource.data.championId == resource.data.championId && request.resource.data.id == resource.data.id;
    }

    /**
     * @description Controls access to parent user profiles.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @deny (get) An authenticated user 'user_abc' cannot get the profile of 'user_xyz'.
     * @principle Restricts access to a user's own data tree and enforces self-creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingOwnProfile(userId);
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Controls access to champion (child) profiles owned by a parent.
       * @path /users/{userId}/champions/{championId}
       * @allow (get, list, create, update, delete) The parent ('userId') can manage their own champion profiles.
       * @deny (get) User 'user_abc' cannot access champions belonging to 'user_xyz'.
       * @principle Enforces document ownership for all operations based on the parent's UID in the path.
       */
      match /champions/{championId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedChampion(userId, championId);
        allow update: if isUpdatingOwnedChampion(userId);
        allow delete: if isExistingOwner(userId);

        /**
         * @description Controls access to chores assigned to a specific champion.
         * @path /users/{userId}/champions/{championId}/assignedChores/{assignedChoreId}
         * @allow (get, list, create, update, delete) The parent ('userId') can manage chores assigned to their champion.
         * @deny (list) User 'user_abc' cannot list assigned chores for a champion belonging to 'user_xyz'.
         * @principle Inherits ownership from the parent path, ensuring only the parent can manage these records.
         */
        match /assignedChores/{assignedChoreId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnedAssignedChore(userId, championId, assignedChoreId);
          allow update: if isUpdatingOwnedAssignedChore(userId);
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Controls access to rewards redeemed by a specific champion.
         * @path /users/{userId}/champions/{championId}/redeemedRewards/{redeemedRewardId}
         * @allow (get, list, create, update, delete) The parent ('userId') can manage rewards redeemed by their champion.
         * @deny (create) User 'user_abc' cannot create a redeemed reward record for a champion belonging to 'user_xyz'.
         * @principle Inherits ownership from the parent path, ensuring only the parent can manage these records.
         */
        match /redeemedRewards/{redeemedRewardId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnedRedeemedReward(userId, championId, redeemedRewardId);
          allow update: if isUpdatingOwnedRedeemedReward(userId);
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Controls access to custom rewards created by a parent.
       * @path /users/{userId}/rewards/{rewardId}
       * @allow (get, list, create, update, delete) The parent ('userId') can manage the rewards they have created.
       * @deny (update) User 'user_abc' cannot update a reward created by 'user_xyz'.
       * @principle Enforces document ownership for all operations based on the parent's UID in the path.
       */
      match /rewards/{rewardId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedReward(userId, rewardId);
        allow update: if isUpdatingOwnedReward(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Controls access to the public, preset chores collection.
     * @path /chores/{choreId}
     * @allow (get, list) Any user, including unauthenticated users, can read the list of preset chores.
     * @deny (create, update, delete) No client is allowed to write to this collection.
     * @principle Provides public read access for application data while securing it against all client-side writes.
     */
    match /chores/{choreId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // Writes should be handled by an admin SDK or console
      allow update: if false; // Writes should be handled by an admin SDK or console
      allow delete: if false; // Writes should be handled by an admin SDK or console
    }
  }
}